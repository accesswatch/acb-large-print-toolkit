#!/usr/bin/env python3
"""
Git pre-commit hook: GLOW v2.5.0+ release quality gate.

This hook runs comprehensive checks before each commit to ensure:
- Configuration consistency across Desktop, Office, Web, Docker, CI
- CHANGELOG.md is maintained
- Feature flags are documented
- Documentation is built and embedded
- Code quality standards are met

To skip (not recommended): git commit --no-verify
"""

import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).parent.parent
SCRIPT = REPO_ROOT / "scripts/pre-commit-check.py"

sys.exit(subprocess.call([sys.executable, str(SCRIPT)]))

