# Desktop runtime configuration
#
# Set only the values you need for the features you use.

# Required only for OpenRouter-backed AI heading classification.
OPENROUTER_API_KEY=

# Local Whisper model name used by audio transcription.
WHISPER_MODEL=medium

# Base URL for the DAISY Pipeline REST service.
PIPELINE_URL=http://pipeline:8181/ws

# Optional path to an epubcheck JAR. Leave blank unless you use EPUBCheck validation.
EPUBCHECK_JAR=

# Enable or disable EPUBCheck-backed EPUB auditing.
GLOW_ENABLE_EPUBCHECK=true
