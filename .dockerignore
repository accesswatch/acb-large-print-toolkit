# ==========================================================================
# Docker build context exclusions
# Build context is the repo root (set by docker-compose context: ..)
# Only desktop/src/, desktop/pyproject.toml, and web/ are needed.
# ==========================================================================

# --- Git and IDE ---
.git/
.github/
.gitignore
.history/
.prettierignore
.vscode/

# --- Documentation and metadata ---
docs/
samples/
reference/
templates/
styles/
README.md
LICENSE*
*.md
!CHANGELOG.md

# --- Server credentials (never send to Docker) ---
server.credentials
csedesigns.com.zone

# --- Scripts (host-side only, not in container) ---
scripts/

# --- Office Add-in (TypeScript -- not used by server) ---
office-addin/

# --- Desktop-only files in desktop ---
desktop/build/
desktop/build.py
desktop/dist/
desktop/installer/
desktop/README.md
desktop/LICENSE.txt
desktop/requirements.txt
desktop/src/acb_large_print/cli.py
desktop/src/acb_large_print/cli_main.py
desktop/src/acb_large_print/__main__.py
desktop/src/acb_large_print/gui.py
desktop/src/acb_large_print/__pycache__/
desktop/src/acb_large_print.egg-info/

# --- Web dev/test files (not needed in image) ---
web/tests/
web/.dockerignore
web/docker-compose*.yml
web/Caddyfile*
web/www/
web/.env*
web/README.md

# --- Python artifacts ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
dist/
.pytest_cache/
.coverage
htmlcov/
.venv/
venv/
