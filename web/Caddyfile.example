# Caddyfile.example -- Copy to Caddyfile and replace domain names
#
# Usage:
#   cp Caddyfile.example Caddyfile
#   nano Caddyfile    # replace csedesigns.com with your domain
#
# This configures:
#   - csedesigns.com / www.csedesigns.com -- static site from ./www/
#   - lp.csedesigns.com + glow.bits-acb.org -- reverse proxy to Flask/Gunicorn

# Main website -- static files
csedesigns.com, www.csedesigns.com {
    root * /srv/www
    file_server
    encode gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy strict-origin-when-cross-origin
    }
}

# ACB Large Print web application -- reverse proxy to Flask/Gunicorn
lp.csedesigns.com, glow.bits-acb.org {
    # Speech Studio document synthesis and Listen Live streaming can take several
    # minutes for long documents.  The transport block sets generous timeouts so
    # that Caddy does not close the connection mid-synthesis.
    #
    # response_header_timeout: time to wait for the FIRST response byte from
    #   Gunicorn.  Speech Studio streams WAV/SSE immediately, so even a 30-second
    #   timeout is plenty.  Set higher if you have very slow hardware.
    # read_timeout: total time allowed to read the full upstream response body
    #   (the WAV stream).  3600 s = 1 hour, which covers any practical document.
    # dial_timeout: connection establishment to Gunicorn (should be near-instant).
    reverse_proxy web:8000 {
        transport http {
            dial_timeout         10s
            response_header_timeout 60s
            read_timeout         3600s
        }
        # Disable buffering for Server-Sent Events (Listen Live) and
        # streaming WAV downloads so chunks reach the client immediately.
        flush_interval -1
    }
    encode gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        Content-Security-Policy "default-src 'none'; script-src 'self'; connect-src 'self'; style-src 'self'; img-src 'self'; media-src 'self' blob:; font-src 'self'; form-action 'self'; frame-ancestors 'none'; base-uri 'self'"
        Strict-Transport-Security "max-age=63072000; includeSubDomains"
    }
}
